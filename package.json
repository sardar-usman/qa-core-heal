{
  "name": "qa-core-heal",
  "version": "0.1.0",
  "description": "Deterministic selector healing for Playwright specs. No LLM, no API key.",
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "qa-core-heal": "dist/cli.js"
  },
  "files": [
    "dist",
    "skill",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "heal": "npm run build && node dist/cli.js",
    "demo": "npm run build && node example-project/scripts/demo.mjs",
    "evals": "npm run build && node evals/run-evals.mjs",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@playwright/test": "1.60.0",
    "playwright": "1.60.0",
    "qa-core-heal": "^0.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0"
  }
}
